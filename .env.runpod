# .env.runpod — HermesCraft on RunPod A6000 48GB
# All services on localhost — no proxy latency
# Copy to .env or source directly via start-stack.sh

# LLM Inference (on-pod, no proxy needed)
VLLM_URL=http://localhost:8000/v1
VLLM_API_KEY=not-needed
MODEL_NAME=hermes
MAX_TOKENS=128
TEMPERATURE=0.6

# Minecraft Server (on-pod Docker)
MC_HOST=localhost
MC_PORT=25565

# Agent Config
TICK_MS=3000
AGENT_MODE=open_ended
