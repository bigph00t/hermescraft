# LLM Inference
# On RunPod: VLLM_URL=http://localhost:8000/v1 (on-pod, no proxy latency)
# Remote:    VLLM_URL=https://YOUR_POD_ID-8000.proxy.runpod.net/v1
VLLM_URL=http://localhost:8000/v1
VLLM_API_KEY=not-needed
MODEL_NAME=hermes

# MAX_TOKENS — caps LLM output length. 128 for action calls on A6000 keeps latency <3s.
# Qwen3.5 thinking tokens count against this budget. If agent responses are truncated,
# increase to 256 or 384 (but expect proportionally longer response times).
MAX_TOKENS=128
TEMPERATURE=0.6

# HermesBridge Mod
MOD_URL=http://localhost:3001

# Streaming (optional — any RTMP endpoint)
STREAM_RTMP_URL=
STREAM_KEY=

# Agent
TICK_MS=3000
LOG_LEVEL=info

# Hermes Agent (for hermescraft.sh / steve-start.sh mode)
# HERMESCRAFT_MODEL=NousResearch/Hermes-4-405B
# HERMESCRAFT_BRIDGE=http://localhost:3001
# HERMESCRAFT_GOAL=Defeat the Ender Dragon

# Agent identity
# AGENT_NAME=hermes
# AGENT_MODE=phased         # phased | open_ended | directed
# AGENT_SOUL=               # Path to SOUL-*.md (optional, auto-detected by name)
# AGENT_GOAL=               # Only for directed mode

# Background Brain (Phase 15: Dual-Brain Architecture)
# Secondary LLM for planning/reflection — runs every 30s asynchronously
# BACKGROUND_BRAIN_URL=http://localhost:8001/v1
# BACKGROUND_MODEL_NAME=qwen3
# BACKGROUND_MAX_TOKENS=1024
# BACKGROUND_INTERVAL_MS=30000
